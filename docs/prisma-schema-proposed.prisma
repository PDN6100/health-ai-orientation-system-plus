// Proposition de schéma Prisma pour la plateforme automobile

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  FLEET_MANAGER
  CENTER_AGENT
  INSURANCE_AGENT
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum ComplianceStatus {
  COMPLIANT
  EXPIRING_SOON
  EXPIRED
  UNKNOWN
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CANCELED
  COMPLETED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum PaymentMethod {
  WAVE
  ORANGE_MONEY
}

enum PaymentStatus {
  INITIATED
  PAID
  FAILED
  REFUNDED
}

model User {
  id            String        @id @default(cuid())
  firstName     String
  lastName      String
  phone         String        @unique
  email         String        @unique
  passwordHash  String
  role          UserRole
  city          String?
  region        String?
  status        AccountStatus @default(PENDING)
  emailVerified Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  vehicles      Vehicle[]
  contracts     InsuranceContract[]
  notifications Notification[]
  tickets       SupportTicket[]
}

model Vehicle {
  id               String           @id @default(cuid())
  ownerId          String
  plate            String           @unique
  brand            String
  model            String
  year             Int
  type             String
  registrationDoc  String?
  complianceStatus ComplianceStatus @default(UNKNOWN)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  owner            User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  inspections      Inspection[]
  appointments     Appointment[]
  contracts        InsuranceContract[]
  documents        Document[]
}

model TechnicalCenter {
  id          String        @id @default(cuid())
  name        String
  phone       String
  email       String?
  city        String
  region      String
  address     String
  openHours   Json
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  inspections Inspection[]
  appointments Appointment[]
}

model Inspection {
  id             String           @id @default(cuid())
  vehicleId      String
  centerId       String
  inspectionDate DateTime
  expiresAt      DateTime
  status         ComplianceStatus
  certificateUrl String?
  createdAt      DateTime         @default(now())

  vehicle        Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  center         TechnicalCenter  @relation(fields: [centerId], references: [id])
}

model Appointment {
  id          String            @id @default(cuid())
  vehicleId   String
  centerId    String
  requestedBy String
  date        DateTime
  status      AppointmentStatus @default(REQUESTED)
  notes       String?
  createdAt   DateTime          @default(now())

  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  center      TechnicalCenter   @relation(fields: [centerId], references: [id])
}

model InsuranceCompany {
  id        String              @id @default(cuid())
  name      String
  phone     String?
  email     String?
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())

  offers    InsuranceOffer[]
  contracts InsuranceContract[]
}

model InsuranceOffer {
  id          String           @id @default(cuid())
  companyId   String
  title       String
  description String
  annualPrice Decimal          @db.Decimal(12, 2)
  active      Boolean          @default(true)

  company     InsuranceCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model InsuranceContract {
  id              String           @id @default(cuid())
  userId          String
  vehicleId       String
  companyId       String
  policyNumber    String
  startsAt        DateTime
  endsAt          DateTime
  status          ComplianceStatus
  certificateUrl  String?
  createdAt       DateTime         @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle         Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  company         InsuranceCompany @relation(fields: [companyId], references: [id])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  title     String
  message   String
  channel   NotificationChannel
  status    NotificationStatus @default(PENDING)
  sendAt    DateTime
  sentAt    DateTime?

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String        @id @default(cuid())
  userId    String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  status    PaymentStatus @default(INITIATED)
  providerRef String?
  createdAt DateTime      @default(now())
}

model Document {
  id        String   @id @default(cuid())
  vehicleId String?
  userId    String?
  type      String
  url       String
  createdAt DateTime @default(now())

  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId       String
  subject      String
  description  String
  status       String  @default("OPEN")
  createdAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
